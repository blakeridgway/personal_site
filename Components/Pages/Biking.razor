@page "/biking"
@using PersonalSite.Models
@using PersonalSite.Services
@inject ICyclingService CyclingService

<PageTitle>Cycling | Blake Ridgway</PageTitle>
<HeadContent>
    <meta property="og:title" content="Cycling Performance | Blake Ridgway" />
    <meta property="og:description" content="Tracking 5,000+ miles annually with power meter analytics, training data, and expedition planning powered by Intervals.icu." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="/biking" />
    <meta property="og:site_name" content="Blake Ridgway" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Cycling Performance | Blake Ridgway" />
    <meta name="twitter:description" content="Tracking 5,000+ miles annually with power meter analytics, training data, and expedition planning." />
</HeadContent>

<!-- Page Header: Terminal Window with Live Stats -->
<section style="background: var(--bg-dark); border-bottom: 1px solid var(--border-color); padding: 3.5rem 0;">
    <div class="container-lg">
        <div class="terminal-window" style="max-width: 600px;">
            <div class="terminal-header">
                <span class="terminal-dot red"></span>
                <span class="terminal-dot yellow"></span>
                <span class="terminal-dot green"></span>
                <span class="ms-2">blake&#64;ridgway:~/cycling</span>
            </div>
            <div class="terminal-body">
                <div class="term-prompt">cat ytd_stats.json</div>
                <div class="term-output mb-3">
                    <span class="text-muted">{</span><br>
                    <span class="term-comment">&nbsp; "miles":&nbsp;&nbsp;&nbsp;</span><span class="text-primary-custom">"@_stats.Distance.ToString("N0")"</span><span class="text-muted">,</span><br>
                    <span class="term-comment">&nbsp; "elevation":</span><span class="text-primary-custom">"@_stats.Elevation.ToString("N0")ft"</span><span class="text-muted">,</span><br>
                    <span class="term-comment">&nbsp; "rides":&nbsp;&nbsp;</span><span class="text-primary-custom">"@_stats.Count"</span><span class="text-muted">,</span><br>
                    <span class="term-comment">&nbsp; "avg_speed":</span><span class="text-primary-custom">"@_stats.AvgSpeed.ToString("N1")mph"</span><br>
                    <span class="text-muted">}</span>
                </div>
                <div class="term-prompt cursor-blink">&nbsp;</div>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<div class="container-lg py-5">
    <div class="row g-5">
        <div class="col-lg-8">
            <!-- YTD Performance -->
            <section class="mb-5">
                <div class="section-header">
                    <span class="section-title">// @DateTime.Now.Year performance</span>
                </div>
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon blue">
                                <i class="bi bi-speedometer2"></i>
                            </div>
                            <div class="stat-value blue">@_stats.Distance.ToString("N0")</div>
                            <div class="stat-label">Miles</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon green">
                                <i class="bi bi-graph-up"></i>
                            </div>
                            <div class="stat-value green">@((_stats.Elevation / 1000).ToString("N1"))k</div>
                            <div class="stat-label">Feet</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon orange">
                                <i class="bi bi-clock"></i>
                            </div>
                            <div class="stat-value orange">@_stats.Time.ToString("N0")</div>
                            <div class="stat-label">Hours</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card">
                            <div class="stat-icon purple">
                                <i class="bi bi-lightning"></i>
                            </div>
                            <div class="stat-value purple">@_stats.AvgSpeed.ToString("N1")</div>
                            <div class="stat-label">Avg MPH</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Recent Rides -->
            <section>
                <div class="section-header">
                    <span class="section-title">// recent rides</span>
                </div>

                @if (_activities.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var activity in _activities)
                        {
                            <div class="card-glass p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <div class="activity-type mb-2">
                                            <i class="bi bi-bicycle"></i>
                                            Ride
                                        </div>
                                        <h3 class="h6 mb-1 font-mono">@activity.Name</h3>
                                        <small class="text-muted font-mono">@activity.Date</small>
                                    </div>
                                    <span class="blog-card-category cycling">@activity.Distance mi</span>
                                </div>
                                <div class="d-flex flex-wrap gap-4 mt-3 pt-3" style="border-top: 1px solid var(--border-color);">
                                    <div class="activity-stat">
                                        <i class="bi bi-speedometer text-primary"></i>
                                        <span class="fw-semibold">@activity.AvgSpeed</span>
                                        <span class="text-muted">mph</span>
                                    </div>
                                    <div class="activity-stat">
                                        <i class="bi bi-graph-up text-primary"></i>
                                        <span class="fw-semibold">@activity.Elevation.ToString("N0")</span>
                                        <span class="text-muted">ft</span>
                                    </div>
                                    <div class="activity-stat">
                                        <i class="bi bi-clock text-primary"></i>
                                        <span class="fw-semibold">@activity.Duration</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="card-glass p-5 text-center">
                        <p class="font-mono text-muted mb-0">// loading activity data...</p>
                    </div>
                }
            </section>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card-glass p-4 sticky-top" style="top: 80px;">
                <span class="section-title d-block mb-3">// data source</span>
                <p class="small text-muted mb-3">
                    All cycling data is automatically synced from Intervals.icu using their REST API.
                </p>
                <div class="d-flex align-items-center gap-2 mb-4">
                    @if (CyclingService.IsAvailable)
                    {
                        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--data-green); display: inline-block; flex-shrink: 0;"></span>
                        <span class="small font-mono text-muted">live data connected</span>
                    }
                    else
                    {
                        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--data-orange); display: inline-block; flex-shrink: 0;"></span>
                        <span class="small font-mono text-muted">using sample data</span>
                    }
                </div>

                <div class="section-divider my-3"></div>

                <span class="section-title d-block mb-3">// goals</span>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1" style="font-family: var(--font-mono); font-size: 0.8rem;">
                        <span class="text-muted">annual distance</span>
                        <span style="color: var(--primary);">@((_stats.Distance / 5000 * 100).ToString("N0"))%</span>
                    </div>
                    <div class="progress" style="height: 4px; background: var(--bg-elevated); border-radius: 2px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: @(Math.Min(100, _stats.Distance / 5000 * 100))%; background: var(--primary); border-radius: 2px;">
                        </div>
                    </div>
                    <small class="text-muted font-mono">@_stats.Distance.ToString("N0") / 5,000 mi</small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CyclingStats _stats = new();
    private IEnumerable<CyclingActivity> _activities = Enumerable.Empty<CyclingActivity>();

    protected override async Task OnInitializedAsync()
    {
        _stats = await CyclingService.GetYtdStatsAsync();
        _activities = await CyclingService.GetRecentActivitiesAsync(5);
    }
}
