@page "/Error"
@using System.Diagnostics

<PageTitle>Error | Blake Ridgway</PageTitle>

<div style="min-height: 60vh; display: flex; align-items: center; padding: 3rem 0;">
    <div class="container-lg">
        <div class="terminal-window" style="max-width: 560px;">
            <div class="terminal-header">
                <span class="terminal-dot red"></span>
                <span class="terminal-dot yellow"></span>
                <span class="terminal-dot green"></span>
                <span class="ms-2">blake&#64;ridgway:~</span>
            </div>
            <div class="terminal-body">
                <div class="term-prompt">status</div>
                <div class="term-output mb-3" style="color: var(--data-red);">
                    error: an unhandled exception occurred
                </div>

                @if (ShowRequestId)
                {
                    <div class="term-prompt">echo $REQUEST_ID</div>
                    <div class="term-output mb-3">@RequestId</div>
                }

                <div class="term-prompt">cat recovery.txt</div>
                <div class="term-output mb-4">
                    try refreshing the page, or head back home.
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a href="/" class="btn btn-outline-primary btn-sm">~/home</a>
                    <a href="/blog" class="btn btn-outline-primary btn-sm">~/blog</a>
                </div>

                <div class="term-prompt mt-3 cursor-blink">&nbsp;</div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
